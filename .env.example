# Discord bot token (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# Optional: Guild ID for faster slash command sync (instant vs ~1 hour)
DISCORD_GUILD_ID=

# Telegram bot token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Optional: Comma-separated Discord channel IDs where commands are allowed
ALLOWED_DISCORD_CHANNELS=

# Optional: Comma-separated Telegram user IDs who can use commands
ALLOWED_TELEGRAM_USERS=

# ZMT Control Plane integration (optional)
ZMT_ENABLED=false
ZMT_CP_URL=
ZMT_REGISTRATION_KEY=
ZMT_AGENT_NAME=
